# Required
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_USER_ID=your-telegram-user-id

# Optional
# CLAUDE_PATH=/opt/homebrew/bin/claude
# CLAUDE_TIMEOUT=300
# ALLOWED_BASE=~/Documents

# For /note skill (save ideas to Notion)
